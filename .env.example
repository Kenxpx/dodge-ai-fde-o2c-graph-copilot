APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Choose one:
# none | gemini | openai_compatible
LLM_PROVIDER=none

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI-compatible providers such as Groq or OpenRouter
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1-mini
